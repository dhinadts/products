datasource db {
  provider = "mongodb"
  url      = env("MONGO_URI")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

model User {
  id            String   @id @map("_id") @default(auto()) @db.ObjectId
  name          String
  email         String   @unique
  passwordHash  String
  role          String
  refreshTokens String[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model LedgerEntry {
  id          String   @id @map("_id") @default(auto()) @db.ObjectId
  date        DateTime
  particulars String
  ledgerRef   String
  debit       Float
  credit      Float
  status      String
  tags        String[]
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BalanceSheetItem {
  id        String   @id @map("_id") @default(auto()) @db.ObjectId
  name      String
  group     String
  type      String
  value     Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id        String   @id @map("_id") @default(auto()) @db.ObjectId
  title     String
  detail    String
  time      String
  color     String
  level     String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}
